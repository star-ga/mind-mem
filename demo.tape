# mind-mem demo — terminal recording for README
# Pre-run: bash demo-setup.sh
Output demo.gif

Set FontSize 15
Set Width 960
Set Height 480
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set Padding 16

Type 'mind-mem-recall -q "API decisions" --workspace ~/demo-workspace 2>/dev/null'
Enter
Sleep 3s

Type "mind-mem-scan ~/demo-workspace 2>/dev/null"
Enter
Sleep 4s
